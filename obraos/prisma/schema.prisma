// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =============================================================================
// GOBERNANZA Y ADMIN
// =============================================================================

enum RolEnum {
  ADMIN          // Control total: usuarios, plataforma, contenido
  GERENCIA       // Reportes, proyectos, config financiera
  PROJECT_MANAGER
  SUPERVISOR
}

enum EstadoUsuarioEnum {
  ACTIVO
  INACTIVO
  SUSPENDIDO
}

model Usuario {
  id             String           @id @default(cuid())
  nombre         String
  email          String           @unique
  passwordHash   String           @map("password_hash")
  rol            RolEnum
  estado         EstadoUsuarioEnum @default(ACTIVO)
  modulosAcceso  Json?            @map("modulos_acceso") // ["dashboard","visor","proyectos","materiales","equipo"] para usuarios no-admin
  avatarUrl      String?          @map("avatar_url")
  ultimoAcceso   DateTime?        @map("ultimo_acceso")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  creadoPorId   String?          @map("creado_por_id")
  creadoPor     Usuario?         @relation("UsuariosCreados", fields: [creadoPorId], references: [id])
  usuariosCreados Usuario[]      @relation("UsuariosCreados")
  proyectosAsignados Proyecto[]  @relation("PM_Proyectos")
  auditLogs     AuditLog[]
}

// RBAC: roles con permisos granulares (escalable)
model Rol {
  id          String   @id @default(cuid())
  codigo      RolEnum  @unique
  nombre      String
  descripcion String?
  permisos    RolPermiso[]
}

model Permiso {
  id          String   @id @default(cuid())
  codigo      String   @unique  // ej: "users.create", "platform.settings.edit"
  modulo      String   // users | platform | projects | catalog | reports
  descripcion String?
  roles       RolPermiso[]
}

model RolPermiso {
  rolId     String
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permisoId String
  permiso   Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)
  @@id([rolId, permisoId])
}

// Configuración y contenido de la plataforma (controlado por admin)
model ConfiguracionPlataforma {
  id        String   @id @default(cuid())
  clave     String   @unique  // ej: "site_name", "maintenance_mode"
  valor     String   @db.Text
  tipo      String   @default("string")  // string | json | boolean | number
  categoria String   @default("general") // general | branding | content | features
  descripcion String?
  updatedAt DateTime @updatedAt @map("updated_at")
}

// Contenido editable (landing, términos, FAQs, etc.)
model ContenidoPlataforma {
  id        String   @id @default(cuid())
  slug      String   @unique  // ej: "landing-hero", "terms", "privacy"
  titulo    String?
  cuerpo    String   @db.LongText
  version   Int      @default(1)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

// Auditoría de acciones admin
model AuditLog {
  id         String   @id @default(cuid())
  usuarioId  String?
  usuario    Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  accion     String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT
  modulo     String   // users | platform | projects | etc
  entidadId  String?  @map("entidad_id")
  detalles   Json?    // payload de cambios
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
}

// =============================================================================
// DOMINIO obrit (Proyectos, Fases, Materiales, 3D)
// =============================================================================

enum StatusEnum {
  PENDING
  ACTIVE
  DONE
}

enum NivelEnum {
  OK
  MEDIO
  BAJO
  AGOTADO
}

enum SemaforoEnum {
  VERDE
  ROJO
}

enum CategoriaEnum {
  MAMPOSTERIA
  CIMENTACION
  ESTRUCTURA
  ACABADOS
  MEZCLAS
  INSTALACIONES
}

// Catálogo editable en Admin para etiquetas y orden de categorías de materiales
model CategoriaMaterialConfig {
  id        String   @id @default(cuid())
  slug      String   @unique // Debe coincidir con un valor de CategoriaEnum
  nombre    String
  orden     Int      @default(0)
  activa    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

enum TipoProyectoEnum {
  RESIDENCIAL
  APARTAMENTOS
  VILLAS
  CONDOMINIO
  COMERCIAL
}

enum StatusProyectoEnum {
  PLANIFICACION
  ACTIVO
  PAUSADO
  ENTREGADO
}

enum TipoTechoEnum {
  PIRAMIDAL
  PLANO
  DOS_AGUAS
}

model Proyecto {
  id                     String              @id @default(cuid())
  nombre                 String
  tipo                   TipoProyectoEnum
  ubicacion              String
  numUnidades            Int                 @map("num_unidades")
  pmAsignadoId           String              @map("pm_asignado_id")
  pmAsignado             Usuario             @relation("PM_Proyectos", fields: [pmAsignadoId], references: [id])
  precioVenta            Float               @map("precio_venta")
  margenObjetivo         Float               @map("margen_objetivo")
  pctCostosIndirectos    Float               @map("pct_costos_indirectos")
  pctContingencia        Float               @map("pct_contingencia")
  presupuestoTotal       Float?              @map("presupuesto_total") // Presupuesto de obra; se resta al agregar materiales a fases
  imagenUrl              String?             @map("imagen_url") // Imagen de portada para tarjeta de proyecto
  status                 StatusProyectoEnum  @default(ACTIVO)
  fechaEntregaEstimada   DateTime?           @map("fecha_entrega_estimada")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  fases                  Fase[]
  unidades               Unidad[]
  partes3D               Parte3D[]
  planillas              Planilla[]
  presupuestoRubros      PresupuestoRubro[]
  lotesMaterial          LoteMaterial[]
  desembolsos            DesembolsoProyecto[]
}

// Límite de presupuesto por rubro (materiales, planilla, tipos de servicio). Flexible: agregar rubros sin migraciones.
model PresupuestoRubro {
  id              String   @id @default(cuid())
  proyectoId      String   @map("proyecto_id")
  proyecto        Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  rubro           String   // "materiales" | "planilla" | "Renta grúa" | "Fletes" | etc.
  pctPresupuesto  Float    @map("pct_presupuesto") // 0-1, ej. 0.50 = 50%
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([proyectoId, rubro])
  @@index([proyectoId])
}

// Registro de fondos desembolsados al proyecto (por tramo o por unidad)
model DesembolsoProyecto {
  id          String    @id @default(cuid())
  proyectoId  String    @map("proyecto_id")
  proyecto    Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  unidadId    String?   @map("unidad_id")
  unidad      Unidad?   @relation(fields: [unidadId], references: [id], onDelete: SetNull)
  monto       Float
  fecha       DateTime  @default(now())
  descripcion String?   @map("descripcion")
  rubro       String?   // opcional: "materiales" | "planilla" | "otros"

  @@index([proyectoId])
  @@index([unidadId])
}

// =============================================================================
// PLANILLA
// =============================================================================

enum EstadoPlanillaEnum {
  BORRADOR
  PAGADA
}

enum UnidadPlanillaEnum {
  DIA
  M2
  M3
}

model Planilla {
  id           String            @id @default(cuid())
  proyectoId   String            @map("proyecto_id")
  proyecto     Proyecto          @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  nombre       String            // Nombre del bloque/cubo de planilla
  periodo      String?
  estado       EstadoPlanillaEnum @default(BORRADOR)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  registros         PlanillaRegistro[]
  asignaciones      PlanillaAsignadaFase[]
  asignacionesTarea PlanillaAsignadaTarea[]

  @@index([proyectoId])
}

// Registros dentro del bloque: Nombre, Unidad (día/m²/m³), Tarifa
model PlanillaRegistro {
  id         String              @id @default(cuid())
  planillaId String              @map("planilla_id")
  planilla   Planilla            @relation(fields: [planillaId], references: [id], onDelete: Cascade)
  nombre     String
  unidad     UnidadPlanillaEnum   // DIA | M2 | M3
  tarifa     Float
  createdAt  DateTime            @default(now()) @map("created_at")
  asignacionesTarea PlanillaRegistroAsignadoTarea[]

  @@index([planillaId])
}

model PlanillaAsignadaFase {
  id         String  @id @default(cuid())
  planillaId String  @map("planilla_id")
  planilla   Planilla @relation(fields: [planillaId], references: [id], onDelete: Cascade)
  faseId     String  @map("fase_id")
  fase       Fase    @relation(fields: [faseId], references: [id], onDelete: Cascade)
  monto      Float

  @@unique([planillaId, faseId])
  @@index([planillaId])
  @@index([faseId])
}

// Asignación de bloque de planilla a tarea+unidad: suma de tarifas del bloque × cantidad (monto total)
model PlanillaAsignadaTarea {
  id         String              @id @default(cuid())
  planillaId String              @map("planilla_id")
  planilla   Planilla            @relation(fields: [planillaId], references: [id], onDelete: Cascade)
  tareaId    String              @map("tarea_id")
  tarea      Tarea               @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  unidadId   String              @map("unidad_id")
  unidad     Unidad              @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  unidadTipo UnidadPlanillaEnum  @map("unidad_tipo") // DIA | M2 | M3
  cantidad   Float
  monto      Float               // (suma tarifas del bloque en esta unidad) × cantidad
  createdAt  DateTime            @default(now()) @map("created_at")

  @@index([planillaId])
  @@index([tareaId])
  @@index([unidadId])
}

// Asignación de registro de planilla a tarea+unidad (legacy: por persona)
model PlanillaRegistroAsignadoTarea {
  id                 String          @id @default(cuid())
  planillaRegistroId String          @map("planilla_registro_id")
  planillaRegistro   PlanillaRegistro @relation(fields: [planillaRegistroId], references: [id], onDelete: Cascade)
  tareaId            String          @map("tarea_id")
  tarea              Tarea           @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  unidadId           String          @map("unidad_id")
  unidad             Unidad          @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  cantidad           Float
  monto              Float           // cantidad * tarifa
  createdAt          DateTime        @default(now()) @map("created_at")

  @@index([planillaRegistroId])
  @@index([tareaId])
  @@index([unidadId])
}

// =============================================================================
// COSTOS VARIOS (SERVICIOS)
// =============================================================================

// Catálogo de fases predefinidas (Movimiento de tierra, Cimentación, etc.) - Admin
// El usuario las selecciona al crear Bloques; se instancian como Fase en el proyecto
model CatalogoFase {
  id        String   @id @default(cuid())
  nombre    String
  orden     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  fases     Fase[]

  @@index([orden])
}

// Catálogo de tipos de servicio (Renta grúa, Fletes, etc.) - gestionado en Admin
model CatalogoTipoServicio {
  id        String            @id @default(cuid())
  nombre    String
  orden     Int               @default(0)
  activo    Boolean           @default(true)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  servicios CatalogoServicio[]

  @@index([orden])
}

model CatalogoServicio {
  id               String               @id @default(cuid())
  tipoServicioId   String?              @map("tipo_servicio_id")
  tipoServicio     CatalogoTipoServicio? @relation(fields: [tipoServicioId], references: [id])
  nombre           String
  unidad           String
  costoUnitario    Float               @map("costo_unitario")
  activo           Boolean             @default(true)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  serviciosFase    ServicioFase[]
  asignacionesTarea ServicioAsignadoTarea[]

  @@index([nombre])
  @@index([tipoServicioId])
}

model ServicioFase {
  id                 String           @id @default(cuid())
  faseId             String           @map("fase_id")
  fase               Fase             @relation(fields: [faseId], references: [id], onDelete: Cascade)
  servicioId         String           @map("servicio_id")
  servicio           CatalogoServicio @relation(fields: [servicioId], references: [id])
  cantidadRequerida  Int              @map("cantidad_requerida")

  @@unique([faseId, servicioId])
  @@index([faseId])
  @@index([servicioId])
}

// Asignación de servicio (costo varios) a tarea+unidad
model ServicioAsignadoTarea {
  id          String           @id @default(cuid())
  servicioId  String           @map("servicio_id")
  servicio    CatalogoServicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  tareaId     String           @map("tarea_id")
  tarea       Tarea            @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  unidadId    String           @map("unidad_id")
  unidad      Unidad           @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  cantidad    Float
  monto       Float            // cantidad * costoUnitario al asignar
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([servicioId])
  @@index([tareaId])
  @@index([unidadId])
}

model Fase {
  id              String        @id @default(cuid())
  proyectoId      String        @map("proyecto_id")
  proyecto        Proyecto      @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  catalogoFaseId  String?       @map("catalogo_fase_id")
  catalogoFase    CatalogoFase? @relation(fields: [catalogoFaseId], references: [id], onDelete: SetNull)
  nombre          String
  status          StatusEnum    @default(PENDING)
  pctAvance   Int         @default(0) @map("pct_avance")
  fechaInicio DateTime?   @map("fecha_inicio")
  fechaFin    DateTime?   @map("fecha_fin")
  orden       Int         @default(0)
  partes3D    Json?       @map("partes_visibles") // ["foundation","columns","walls",...] - partes visibles al activar esta fase
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  materiales  MaterialFase[]
  partesVisibles FaseParte3D[]
  unidadesFaseActiva Unidad[] @relation("UnidadFaseActiva")
  avancesUnidad AvanceUnidadFase[]
  tareas       Tarea[]
  planillasAsignadas PlanillaAsignadaFase[]
  servicios    ServicioFase[]

  @@index([proyectoId])
}

model MaterialFase {
  id                 String   @id @default(cuid())
  faseId             String   @map("fase_id")
  fase               Fase     @relation(fields: [faseId], references: [id], onDelete: Cascade)
  materialId         String   @map("material_id")
  material           CatalogoMaterial @relation(fields: [materialId], references: [id])
  cantidadRequerida  Int      @map("cantidad_requerida")
  pctEjecutado       Int      @default(0) @map("pct_ejecutado")
  distribucionesUnidad MaterialFaseUnidad[]
  @@unique([faseId, materialId])
  @@index([faseId])
  @@index([materialId])
}

// Asignación de material por unidad: % de cantidadRequerida que va a cada unidad
model MaterialFaseUnidad {
  id              String       @id @default(cuid())
  materialFaseId  String       @map("material_fase_id")
  materialFase    MaterialFase @relation(fields: [materialFaseId], references: [id], onDelete: Cascade)
  unidadId        String       @map("unidad_id")
  unidad          Unidad       @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  porcentaje      Float        @default(0) // 0-100, debe sumar 100 por materialFase
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@unique([materialFaseId, unidadId])
  @@index([materialFaseId])
  @@index([unidadId])
}

model CatalogoMaterial {
  id                  String         @id @default(cuid())
  nombre              String
  categoria           CategoriaEnum
  unidad              String
  stockTotal          Int            @default(0) @map("stock_total") // legacy; se calcula desde lotes
  costoUnitario       Float          @default(0) @map("costo_unitario") // legacy; precio por defecto para nuevos lotes
  presupuestoAsignado Float?         @map("presupuesto_asignado")
  colorHex            String?        @map("color_hex")
  activo              Boolean        @default(true)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  materialesFase      MaterialFase[]
  movimientos         InventarioMovimiento[]
  lotes               LoteMaterial[]
  asignacionesTarea   MaterialAsignadoTarea[]

  @@index([categoria])
}

// Lote de compra: mismo material puede tener varios lotes con distintos precios
model LoteMaterial {
  id                 String               @id @default(cuid())
  catalogoMaterialId String               @map("catalogo_material_id")
  catalogoMaterial   CatalogoMaterial     @relation(fields: [catalogoMaterialId], references: [id], onDelete: Cascade)
  proyectoId         String               @map("proyecto_id")
  proyecto           Proyecto             @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  cantidad           Float                // cantidad restante en stock
  cantidadInicial    Float                @map("cantidad_inicial") // cantidad al crear (para historial)
  precioUnitario     Float                @map("precio_unitario")
  total              Float                // cantidad * precio (almacenado para consistencia)
  descripcion        String?              @map("descripcion") // ej. "Compra Almacén X", "Lote 1"
  createdAt          DateTime             @default(now()) @map("created_at")
  asignaciones       MaterialAsignadoTarea[]

  @@index([catalogoMaterialId])
  @@index([proyectoId])
}

// Asignación de material a una tarea de una unidad
// Origen: CatalogoMaterial (stock de Materiales) o LoteMaterial (lote de compra)
model MaterialAsignadoTarea {
  id                 String            @id @default(cuid())
  catalogoMaterialId String?           @map("catalogo_material_id")
  catalogoMaterial   CatalogoMaterial? @relation(fields: [catalogoMaterialId], references: [id], onDelete: Cascade)
  loteId             String?           @map("lote_id")
  lote               LoteMaterial?     @relation(fields: [loteId], references: [id], onDelete: Cascade)
  tareaId            String            @map("tarea_id")
  tarea              Tarea             @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  unidadId           String            @map("unidad_id")
  unidad             Unidad            @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  cantidad           Float
  monto              Float
  createdAt          DateTime          @default(now()) @map("created_at")

  @@index([catalogoMaterialId])
  @@index([loteId])
  @@index([tareaId])
  @@index([unidadId])
}

enum TipoMovimientoEnum {
  ENTRADA  // compra, ajuste positivo
  SALIDA   // consumo por fase
}

// Trazabilidad: registra cada entrada y salida de material
model InventarioMovimiento {
  id           String             @id @default(cuid())
  materialId   String             @map("material_id")
  material     CatalogoMaterial   @relation(fields: [materialId], references: [id], onDelete: Cascade)
  tipo         TipoMovimientoEnum // ENTRADA | SALIDA
  cantidad     Int
  saldoAntes   Int?               @map("saldo_antes")
  saldoDespues Int?               @map("saldo_despues")
  unidadId     String?            @map("unidad_id")      // atribución opcional
  unidad       Unidad?            @relation(fields: [unidadId], references: [id], onDelete: SetNull)
  faseId       String?            @map("fase_id")        // para SALIDA: fase que consumió
  materialFaseId String?          @map("material_fase_id") // para SALIDA
  proyectoId   String?            @map("proyecto_id")    // para SALIDA
  createdAt    DateTime           @default(now()) @map("created_at")

  @@index([materialId])
  @@index([createdAt])
  @@index([tipo])
}

model Unidad {
  id                   String       @id @default(cuid())
  proyectoId           String       @map("proyecto_id")
  proyecto             Proyecto     @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  numero               Int
  etiqueta             String
  fechaEntregaEstimada DateTime?    @map("fecha_entrega_estimada")
  modeloCasaId         String?      @map("modelo_casa_id")
  modeloCasa       ModeloCasa?  @relation(fields: [modeloCasaId], references: [id], onDelete: SetNull)
  faseActualId     String?      @map("fase_actual_id")
  faseActual       Fase?        @relation("UnidadFaseActiva", fields: [faseActualId], references: [id], onDelete: SetNull)
  pctAvanceGlobal  Float        @default(0) @map("pct_avance_global")
  activa           Boolean      @default(true)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  avancesFase      AvanceUnidadFase[]
  tareasCompletadas TareaCompletadaUnidad[]
  materialesAsignados MaterialFaseUnidad[]
  movimientosInventario InventarioMovimiento[]
  materialesAsignadosTarea MaterialAsignadoTarea[]
  planillasRegistroAsignadas PlanillaRegistroAsignadoTarea[]
  planillasBloqueAsignadas PlanillaAsignadaTarea[]
  serviciosAsignadosTarea ServicioAsignadoTarea[]
  desembolsosProyecto   DesembolsoProyecto[]

  @@unique([proyectoId, numero])
  @@index([proyectoId])
  @@index([modeloCasaId])
  @@index([faseActualId])
}

model Tarea {
  id           String    @id @default(cuid())
  faseId       String    @map("fase_id")
  fase         Fase      @relation(fields: [faseId], references: [id], onDelete: Cascade)
  nombre       String
  orden        Int       @default(0)
  fechaInicio  DateTime? @map("fecha_inicio")
  fechaFin     DateTime? @map("fecha_fin")
  cantidadM2   Float     @default(0) @map("cantidad_m2")
  cantidadM3   Float     @default(0) @map("cantidad_m3")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  completadas  TareaCompletadaUnidad[]
  materialesAsignados MaterialAsignadoTarea[]
  planillasRegistroAsignadas PlanillaRegistroAsignadoTarea[]
  planillasBloqueAsignadas PlanillaAsignadaTarea[]
  serviciosAsignados ServicioAsignadoTarea[]

  @@index([faseId])
}

model TareaCompletadaUnidad {
  tareaId     String   @map("tarea_id")
  tarea       Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  unidadId    String   @map("unidad_id")
  unidad      Unidad   @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  completadaAt DateTime @default(now()) @map("completada_at")

  @@id([tareaId, unidadId])
  @@index([unidadId])
}

model AvanceUnidadFase {
  id           String    @id @default(cuid())
  unidadId     String    @map("unidad_id")
  unidad       Unidad    @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  faseId       String    @map("fase_id")
  fase         Fase      @relation(fields: [faseId], references: [id], onDelete: Cascade)
  pctAvance    Int       @default(0) @map("pct_avance")
  status       StatusEnum @default(PENDING)
  fechaInicio  DateTime? @map("fecha_inicio")
  fechaFin     DateTime? @map("fecha_fin")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([unidadId, faseId])
  @@index([unidadId])
  @@index([faseId])
}

model ModeloCasa {
  id                 String   @id @default(cuid())
  nombre             String
  anchoExterior      Float    @default(10) @map("ancho_exterior")
  profundidadExterior Float   @default(8) @map("profundidad_exterior")
  alturaParedes      Float    @default(5) @map("altura_paredes")
  grosorMuro         Float    @default(0.3) @map("grosor_muro")
  tipoTecho          TipoTechoEnum @default(PIRAMIDAL) @map("tipo_techo")
  numVentanasFront   Int      @default(2) @map("num_ventanas_front")
  numVentanasSide    Int      @default(1) @map("num_ventanas_side")
  tienePuerta        Boolean  @default(true) @map("tiene_puerta")
  configJSON         Json?    @map("config_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  unidades           Unidad[]

  @@index([nombre])
}

model FaseParte3D {
  faseId    String
  fase      Fase     @relation(fields: [faseId], references: [id], onDelete: Cascade)
  parteId   String
  parte     Parte3D  @relation(fields: [parteId], references: [id], onDelete: Cascade)
  visible   Boolean  @default(true)
  orden     Int?
  @@id([faseId, parteId])
}

model Parte3D {
  id         String   @id @default(cuid())
  proyectoId String   @map("proyecto_id")
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  nombre     String
  visible    Boolean  @default(true)
  orden      Int
  geometria  Json     // { tipo: "parametrico"|"modelo", params/url, escala, etc }
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  fases      FaseParte3D[]

  @@index([proyectoId])
}
